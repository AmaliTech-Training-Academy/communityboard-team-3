DB_HOST=postgres
DB_PORT=5432
DB_NAME=communityboard
DB_USER=postgres
DB_PASSWORD=changeme

# ETL Pipeline settings
ETL_EXTRACT_BATCH_SIZE=10000
ETL_LOAD_BATCH_SIZE=5000
ETL_ANONYMIZE_PII=true
ETL_HASH_SALT=communityboard-etl-salt-2024
# KMS — AES-256-GCM encryption for PII
# Provider: "local" (env var key) or "aws" (AWS KMS envelope encryption)
ETL_KMS_PROVIDER=local
# Generate 256-bit key: python -c "import secrets; print(secrets.token_hex(32))"
ETL_KMS_KEY=
# AWS KMS (only when ETL_KMS_PROVIDER=aws)
# ETL_KMS_AWS_KEY_ID=arn:aws:kms:us-east-1:123456789:key/your-key-id
# ETL_KMS_AWS_REGION=us-east-1
