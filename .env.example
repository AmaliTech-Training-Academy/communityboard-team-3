# Database Configuration
POSTGRES_DB=communityboard
POSTGRES_USER=postgres
DB_PASSWORD=your-secure-password-here

# Backend Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/communityboard
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-secure-password-here
JWT_SECRET=your-jwt-secret-key-here

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8080

# Data Engineering Configuration
ETL_KMS_KEY=your-64-char-hex-key-here

# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Replace placeholder values with actual secrets
# 3. NEVER commit the .env file to git
#
# Generate ETL_KMS_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
